{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "APEX-OS: Run Python Backend Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/app.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "APEX-OS: Launch Chrome against http://localhost:5000",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5000",
            "webRoot": "${workspaceFolder}"
        }
    ]
}